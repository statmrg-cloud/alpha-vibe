# ============================================
# Alpha-Vibe 환경 변수 설정
# 이 파일을 .env.local 로 복사한 후 API 키를 입력하세요.
# ============================================

# Anthropic Claude API (https://console.anthropic.com/)
# 회원가입 후 API Keys 메뉴에서 발급
ANTHROPIC_API_KEY=여기에_Claude_API_키_입력

# Alpaca Paper Trading API (https://app.alpaca.markets/)
# 회원가입 후 Paper Trading > API Keys에서 발급
ALPACA_API_KEY=여기에_Alpaca_API_Key_입력
ALPACA_API_SECRET=여기에_Alpaca_Secret_Key_입력
ALPACA_BASE_URL=https://data.alpaca.markets
ALPACA_TRADING_URL=https://paper-api.alpaca.markets
